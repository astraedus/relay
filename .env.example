# DigitalOcean Gradient AI — primary inference (get from cloud.digitalocean.com > AI > API Keys)
DO_MODEL_ACCESS_KEY=dop_v1_...
DO_MODEL=llama3-8b-instruct
DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1/

# Gemini — free fallback if DO not configured (get from aistudio.google.com/apikey)
GEMINI_API_KEY=AIzaSy...

# GitHub — optional, increases rate limits for private repos
GITHUB_TOKEN=ghp_...

# Slack — optional, enables reading messages and posting digests
SLACK_BOT_TOKEN=xoxb-...

# Database — SQLite file path for local dev, postgres:// for prod
DATABASE_URL=relay.db

# App
PORT=8000
LOG_LEVEL=INFO

# Set to true to force mock AI responses (useful for demos)
MOCK_MODE=false
